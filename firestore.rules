rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return request.auth != null && role in getUserData().roles;
    }
    
    function isOwner() {
      return hasRole('owner');
    }
    
    function isManager() {
      return hasRole('manager');
    }

    match /users/{userId} {
      // Anyone logged in can read users
      allow read: if request.auth != null;
      // Owner and Manager can do full update/create/delete
      // A regular user can only update their own fcmToken
      allow create, delete: if isOwner() || isManager();
      allow update: if isOwner() || isManager() || 
                    (request.auth.uid == userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fcmToken']));
    }

    match /sayimlar/{sayimId} {
      // Owners and Managers can read all sayims. Staff can read if invited.
      // Update/Delete is restricted to Owner or Creator.
      allow read: if isOwner() || isManager() || (request.auth != null && request.auth.uid in resource.data.invitedUserIds);
      allow create: if isOwner() || (isManager() && request.resource.data.createdBy == request.auth.uid);
      allow update, delete: if isOwner() || (isManager() && resource.data.createdBy == request.auth.uid);
    }

    match /settings/{document} {
      allow read: if request.auth != null;
      allow write: if isOwner();
    }

    match /davetler/{davetId} {
      // Staff can read their own invites
      // Owner can read all. Managers can read all (to see invites of their sayims)
      allow read: if isOwner() || isManager() || (request.auth != null && resource.data.userId == request.auth.uid);
      // Staff can update their own invite status
      allow update: if isOwner() || isManager() || (request.auth != null && resource.data.userId == request.auth.uid);
      // Only managers/owners can create/delete
      allow create, delete: if isOwner() || isManager();
    }

    match /personel_takvimi/{userId}/gunler/{tarih} {
      // Owner/Manager can read/write. Staff can read/write their own.
      allow read, write: if isOwner() || isManager() || request.auth.uid == userId;
    }

    match /fcm_tokens/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
